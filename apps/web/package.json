{
  "name": "minicard",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages && node -e \"const fs = require('fs'); fs.writeFileSync('.vercel/output/static/.assetsignore', '_worker.js\\n')\"",
    "pages:deploy": "pnpm pages:build && pnpm exec wrangler pages deploy .vercel/output/static",
    "pages:secrets": "node scripts/sync-pages-secrets.mjs"
  },
  "dependencies": {
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.30",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "wrangler": "^4.100.0"
  }
}